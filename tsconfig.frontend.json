{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "skipLibCheck": true,
    "allowJs": false,
    "forceConsistentCasingInFileNames": true,
    "types": []
  },
  "include": [
    "types/surgery.d.ts",
    "main.ts",
    "data.ts",
    "utils/helpers.ts",
    "utils/api.ts",
    "components/sections.ts",
    "components/footer-dynamic.ts",
    "components/header.ts",
    "components/booking-modal.ts",
    "pages/blog.ts",
    "pages/home.ts",
    "pages/category.ts",
    "pages/treatment.ts",
    "pages/doctors.ts",
    "pages/hospitals.ts",
    "pages/search.ts",
    "pages/pet.ts",
    "pages/static.ts"
  ]
}
